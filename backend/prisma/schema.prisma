generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  passwordHash    String
  role            UserRole          @default(USER)
  favoriteMoods   FavoriteMood[]
  playlistHistory PlaylistHistory[]
  sharedPlaylists SharedPlaylist[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Mood {
  id            String         @id @default(cuid())
  key           String         @unique
  name          String
  description   String?
  keywords      Json
  genres        Json
  theme         Json?
  favoriteMoods FavoriteMood[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model FavoriteMood {
  id        String   @id @default(cuid())
  userId    String
  moodId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      Mood     @relation(fields: [moodId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, moodId])
  @@index([moodId])
}

model PlaylistHistory {
  id               String           @id @default(cuid())
  userId           String
  mood             String
  inputType        String           @default("manual")
  journalTextSaved Boolean          @default(false)
  searchQuery      String?
  apiSource        String
  resultData       Json
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedPlaylists  SharedPlaylist[]
  createdAt        DateTime         @default(now())

  @@index([userId])
  @@index([mood])
}

model SharedPlaylist {
  id                String           @id @default(cuid())
  shareId           String           @unique
  userId            String?
  playlistHistoryId String?
  isActive          Boolean          @default(true)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  playlistHistory   PlaylistHistory? @relation(fields: [playlistHistoryId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  expiresAt         DateTime?

  @@index([userId])
  @@index([playlistHistoryId])
}

model ApiLog {
  id           String   @id @default(cuid())
  provider     String
  endpoint     String
  statusCode   Int?
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())
}
